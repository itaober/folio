{
  "name": "folio-extension",
  "version": "1.0.12",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export FOLIO_BUILD_CHANNEL=dev; export VITE_FOLIO_BUILD_CHANNEL=dev; vite",
    "build": "export FOLIO_BUILD_CHANNEL=prod; export VITE_FOLIO_BUILD_CHANNEL=prod; tsc --noEmit && vite build",
    "build:dev": "export FOLIO_BUILD_CHANNEL=dev; export VITE_FOLIO_BUILD_CHANNEL=dev; tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "i18next": "^25.6.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^15.7.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.2.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/chrome": "^0.1.24",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.1.5"
  }
}
